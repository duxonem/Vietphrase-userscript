{
  "manifest_version": 2,
  "name": "Vietphrase Converter MV2",
  "version": "2.2.0",
  "description": "Convert văn bản tiếng Trung kiểu Vietphrase, tối ưu bằng IndexedDB và cơ chế Batch-Translate.",
  "permissions": [
    "storage",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_action": {}
}